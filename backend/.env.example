PORT=3002

# URL kết nối cơ sở dữ liệu CockroachDB
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db_name>?sslmode=verify-full

AI_SERVICE_URL=http://localhost:8000

# OpenWeatherMap API Key
# Đăng ký miễn phí tại: https://openweathermap.org/api
# Sau khi có key, copy vào .env (không phải .env.example)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here

# Ngưỡng binary classification (cm)
# flood_depth_cm < ngưỡng → label 0 (An toàn)
# flood_depth_cm >= ngưỡng → label 1 (Cảnh báo nguy cơ ngập)
FLOOD_BINARY_THRESHOLD_CM=5
